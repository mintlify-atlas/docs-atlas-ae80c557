  "keyFeatures": [
    "In-memory data structure server with sub-millisecond latency",
    "Rich data types: strings, lists, sets, sorted sets, hashes, streams, JSON, bitmaps, hyperloglogs, geospatial",
    "Redis Query Engine for full-text search, vector search, and secondary indexing",
    "Pub/Sub messaging and streaming with consumer groups",
    "Clustering for horizontal scalability and high availability",
    "Replication for data redundancy and read scalability",
    "Persistence with RDB snapshots and AOF logging",
    "Lua scripting and Redis Functions for server-side logic",
    "TLS/SSL support for encrypted connections",
    "ACL-based authentication and authorization",
    "Module system for extending functionality",
    "Time series, probabilistic data structures, and vector databases",
    "Transactions and optimistic locking with WATCH/MULTI/EXEC",
    "Built-in support for caching, session storage, queues, and real-time analytics"
  ],
  "publicApiSurface": [
    "GET/SET - String operations",
    "LPUSH/RPUSH/LPOP/RPOP - List operations",
    "SADD/SMEMBERS/SINTER - Set operations",
    "ZADD/ZRANGE/ZRANK - Sorted set operations",
    "HSET/HGET/HGETALL - Hash operations",
    "XADD/XREAD/XGROUP - Stream operations",
    "PUBLISH/SUBSCRIBE - Pub/Sub messaging",
    "JSON.SET/JSON.GET - JSON operations",
    "FT.CREATE/FT.SEARCH - Search and query",
    "GEOADD/GEORADIUS - Geospatial operations",
    "PFADD/PFCOUNT - HyperLogLog operations",
    "EVAL/EVALSHA - Lua script execution",
    "MULTI/EXEC/WATCH - Transactions",
    "CLUSTER NODES/SLOTS - Cluster management",
    "REPLICAOF/INFO REPLICATION - Replication",
    "CONFIG GET/SET - Configuration",
    "ACL SETUSER/GETUSER - Access control",
    "BGSAVE/BGREWRITEAOF - Persistence",
    "MODULE LOAD/LIST - Module management",
    "redis-cli - Command-line interface",
    "redis-server - Server executable",
    "redis-benchmark - Performance testing",
    "redis-sentinel - High availability"
  ]
}
